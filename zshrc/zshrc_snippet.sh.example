# --- Tab Creation & Output Copying ---

# 1. 'create' — open a new tmux tab (window) in the current working directory.
# Usage: create
function create() {
    if [ -z "$TMUX" ]; then
        echo "create: must be run inside a tmux session" >&2
        return 1
    fi
    tmux new-window -c "$PWD"
}

# 2. 'clast' alias
# Scrapes the actual output of your previous command directly from the Tmux screen buffer!
# This is completely safe and does NOT re-run your previous command.
alias clast='python3 ~/.local/bin/tmux-copy-last | pbcopy && echo "\n\033[0;32m[Output perfectly captured from terminal buffer and copied!]\033[0m"'

# 3. 'ask' function
# Converts natural language to a shell command using Gemini and copies to clipboard.
# Now includes an explanation of the command!
# Usage: ask find all pdf files modified in the last 2 days
function ask() {
    if [ -z "$*" ]; then
        echo "Usage: ask <natural language request>"
        return 1
    fi
    echo -e "\033[0;33mThinking...\033[0m"
    
    local prompt="You are a shell command expert. For the following request, provide the raw shell command and a brief explanation. You MUST wrap your command and explanation in these exact delimiters, with no markdown code blocks:
___CMD_START___
<raw command here>
___CMD_END___
___EXP_START___
<brief explanation here>
___EXP_END___

Request: $*"

    # Run the Gemini CLI headless mode.
    local response=$(gemini -p "$prompt" 2>/dev/null)
    
    # Extract the multi-line command and explanation using awk
    local cmd=$(echo "$response" | awk '/^___CMD_START___/{flag=1; next} /^___CMD_END___/{flag=0} flag')
    local exp=$(echo "$response" | awk '/^___EXP_START___/{flag=1; next} /^___EXP_END___/{flag=0} flag')
    
    if [ -z "$cmd" ]; then
        echo -e "\033[0;31mError generating command.\033[0m"
        return 1
    fi

    echo -e "\n\033[0;32mGenerated Command:\033[0m"
    echo "$cmd"
    echo -e "\n\033[0;36mExplanation:\033[0m"
    echo "$exp"
    
    # Copy ONLY the command to clipboard
    echo -n "$cmd" | pbcopy
    echo -e "\n\033[0;32m[Command ONLY copied to clipboard! Ready to paste.]\033[0m"
}
