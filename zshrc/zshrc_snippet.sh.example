# --- Tab Creation & Output Copying ---

# 1. 'create' — open a new tmux tab (window) in the current working directory.
# Usage: create
function create() {
    if [ -z "$TMUX" ]; then
        echo "create: must be run inside a tmux session" >&2
        return 1
    fi
    tmux new-window -c "$PWD"
}

# 2. 'clast' alias
# Scrapes the actual output of your previous command directly from the Tmux screen buffer!
# This is completely safe and does NOT re-run your previous command.
alias clast='python3 ~/.local/bin/tmux-copy-last | pbcopy && echo "\n\033[0;32m[Output perfectly captured from terminal buffer and copied!]\033[0m"'

# 3. 'ask' function
# Converts natural language to a shell command using kiro-cli's `zshrc-ask`
# basic agent (no MCP, no tool access) and copies it to the clipboard.
# Install the agent first: cp ask-agent.json.example ~/.kiro/agents/zshrc-ask.json
# Usage: ask find all pdf files modified in the last 2 days
function ask() {
    if [ -z "$*" ]; then
        echo "Usage: ask <natural language request>"
        return 1
    fi
    echo -e "\033[0;33mThinking...\033[0m"

    # Run kiro-cli with the basic zshrc-ask agent. stderr is discarded; stdout
    # contains the agent response, kiro-cli decoration (prompt prefix, banners)
    # and a trailing "Credits: X.XX" footer.
    local raw="$(kiro-cli chat --no-interactive --trust-all-tools --agent zshrc-ask "$*" 2>/dev/null)"

    # Strip ANSI escape sequences and leading '> ' prompt prefix so awk can match plain delimiter strings.
    local response="$(printf '%s' "$raw" | LC_ALL=C sed -E 's/\x1b\[[0-9;?]*[A-Za-z]//g; s/\r//g; s/^> //')"

    # Extract command + explanation. The closing delimiter is `===/CMD===` —
    # the leading slash makes it textually distinct from the opening one so
    # the model can't accidentally produce a closing tag that matches the
    # opening pattern.
    local cmd=$(echo "$response" | awk 'index($0,"===/CMD===") {flag=0} flag; index($0,"===CMD===") && !index($0,"===/CMD===") {flag=1}' | sed '/^[[:space:]]*$/d')
    local exp=$(echo "$response" | awk 'index($0,"===/EXP===") {flag=0} flag; index($0,"===EXP===") && !index($0,"===/EXP===") {flag=1}' | sed '/^[[:space:]]*$/d')

    if [ -z "$cmd" ]; then
        echo -e "\033[0;31mError generating command.\033[0m"
        echo "(raw kiro-cli stdout — first 400 chars for debugging:)"
        echo "$response" | head -c 400
        return 1
    fi

    echo -e "\n\033[0;32mGenerated Command:\033[0m"
    echo "$cmd"
    echo -e "\n\033[0;36mExplanation:\033[0m"
    echo "$exp"

    # Copy ONLY the command to clipboard
    echo -n "$cmd" | pbcopy
    echo -e "\n\033[0;32m[Command ONLY copied to clipboard! Ready to paste.]\033[0m"
}

# 4. 'asklast' function
# Grabs the previous command's output from the tmux buffer and feeds it to `ask`.
# Usage: asklast what went wrong
function asklast() {
    local output="$(python3 ~/.local/bin/tmux-copy-last)"
    if [ -z "$output" ]; then
        echo -e "\033[0;31mNo previous command output found.\033[0m"
        return 1
    fi
    ask "given this terminal output: $output — $*"
}

# 5. 'cl' alias — short shortcut for `clear`.
# If your existing ~/.zshrc has `cl` aliased to something else, remove that
# prior definition first so this one wins unambiguously.
alias cl='clear'
