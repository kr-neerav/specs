#!/usr/bin/env python3
import subprocess
import sys

def main():
    # Capture the last 2000 lines of the tmux pane
    result = subprocess.run(['tmux', 'capture-pane', '-pS', '-2000'], capture_output=True, text=True)
    if result.returncode != 0:
        print("Error: Must be run inside tmux.", file=sys.stderr)
        sys.exit(1)

    lines = result.stdout.rstrip().split('\n')

    # The robbyrussell Zsh theme prompt always starts with '➜'
    prompt_indices = [i for i, line in enumerate(lines) if '➜' in line or line.startswith('❯')]

    if len(prompt_indices) < 2:
        print("Could not find previous command output in terminal history.", file=sys.stderr)
        sys.exit(1)

    # The last prompt is the one where 'copylast' was typed
    # The second to last prompt is the previous command
    start_idx = prompt_indices[-2]
    end_idx = prompt_indices[-1]

    # Extract all lines between the two prompts
    output_lines = lines[start_idx+1:end_idx]

    # Remove trailing empty lines from the extracted output
    while output_lines and not output_lines[-1].strip():
        output_lines.pop()

    output = '\n'.join(output_lines)
    print(output, end='')

if __name__ == '__main__':
    main()
